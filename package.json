{
  "name": "node-gles-webgl2",
  "version": "0.2.0",
  "description": "Headless WebGL2 / OpenGL ES 3 runtime for Node.js backed by ANGLE",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsafdsaf132/node-gles-webgl2.git"
  },
  "bugs": {
    "url": "https://github.com/dsafdsaf132/node-gles-webgl2/issues"
  },
  "homepage": "https://github.com/dsafdsaf132/node-gles-webgl2#readme",
  "engines": {
    "node": ">=8.11.0"
  },
  "license": "Apache-2.0",
  "keywords": [
    "webgl",
    "webgl2",
    "opengl-es",
    "gles3",
    "angle",
    "headless-webgl",
    "node-webgl",
    "webgl-context",
    "webgl2-context",
    "offscreen-rendering",
    "wasm-bindgen",
    "native-addon"
  ],
  "files": [
    "binding",
    "binding.gyp",
    "dist/binding.d.ts",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/version.d.ts",
    "dist/version.js",
    "scripts/clean-dist.js",
    "scripts/install.js",
    "test/regl-smoke.js",
    "test/three-smoke.js",
    "test/visual-3d-texture-arrays.js",
    "test/webgl2-smoke.js",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.js && tsc --sourceMap false",
    "build-npm": "./scripts/build-npm.sh",
    "ci": "npm run build && npx --yes node-gyp rebuild",
    "format": "clang-format -i -style=Google binding/*.cc binding/*.h",
    "install": "node scripts/install.js",
    "test": "npm run test:webgl2 && npm run test:regl",
    "test:regl": "node test/regl-smoke.js",
    "test:three": "node test/three-smoke.js",
    "visual:3d-textures": "node test/visual-3d-texture-arrays.js",
    "test:webgl2": "node test/webgl2-smoke.js"
  },
  "devDependencies": {
    "@types/bindings": "1.3.0",
    "@types/node": "10.11.0",
    "@types/progress": "2.0.3",
    "@types/webgl2": "0.0.4",
    "regl": "2.1.1",
    "three": "0.184.0",
    "typescript": "3.0.3"
  },
  "dependencies": {
    "adm-zip": "^0.4.13",
    "bindings": "^1.3.0",
    "https-proxy-agent": "^5.0.1",
    "progress": "^2.0.3"
  }
}
